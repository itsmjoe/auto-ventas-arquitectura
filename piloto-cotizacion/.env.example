# Configuración del piloto (copiar a .env). Nunca versionar secretos reales.
COTIZACION_TASA_IMPUESTO=0.12
COTIZACION_VIGENCIA_MINUTOS=60
COTIZACION_TIMEOUT_SOCIOS=2.0
# Modos de los socios para demostrar edge cases: ok | timeout | caido
COTIZACION_MODO_BANCO=ok
COTIZACION_MODO_ASEGURADORA=ok
# Orígenes reales por HTTP: si se define la URL se usa el adaptador HTTP; si se deja
# vacío, el mock. Mismo puerto, distinto adaptador.
# COTIZACION_CATALOGO_URL=http://catalogo-svc:8000
# COTIZACION_BANCO_URL=http://banco-svc:8000
# COTIZACION_ASEGURADORA_URL=http://aseguradora-svc:8000
